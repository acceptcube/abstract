# abstract / $ART  —  copy to .env and fill in
# Image generation
OPENROUTER_API_KEY=
IMAGE_MODEL=openai/gpt-5.4-image-2

# Solana
SOLANA_NETWORK=mainnet
HELIUS_API_KEY=
DEPLOYER_KEYPAIR=
DEPLOYER_PUBKEY=

# Token (set after the $ART coin is launched on pump.fun)
TOKEN_MINT=
HOLD_THRESHOLD=5000000
HOLD_DURATION_SECONDS=900
WINNER_COUNT=100

# Optional exclusions, comma separated
EXCLUDED_WALLETS=

# IPFS pinning
PINATA_JWT=

# Site
SITE_DOMAIN=haldenvoss.art
X_HANDLE=HaldenVoss
